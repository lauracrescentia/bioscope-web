"use client";
import { useState, useEffect } from 'react';
import JournalForm from '@/components/JournalForm';
import JournalList from '@/components/JournalList';
import { BookText } from 'lucide-react';

export interface JournalEntry {
  id: string;
  date: string;
  topic: string;
  learned: string;
  challenging: string;
  application: string;
}

export default function JournalPage() {
  const [entries, setEntries] = useState<JournalEntry[]>([]);
  const [filter, setFilter] = useState('');

  // 1. Load data aman untuk Next.js (Client Side Only)
  useEffect(() => {
    const saved = localStorage.getItem('bioscope_journals');
    if (saved) {
      try {
        setEntries(JSON.parse(saved));
      } catch (e) {
        console.error("Error parsing journals", e);
      }
    }
  }, []);

  // 2. Perbaikan fungsi Save (Ganti OofOmit jadi Omit)
  const saveEntry = (newEntry: Omit<JournalEntry, 'id' | 'date'>) => {
    const entry: JournalEntry = {
      ...newEntry,
      id: Date.now().toString(),
      date: new Date().toLocaleDateString('id-ID', { 
        day: 'numeric', 
        month: 'long', 
        year: 'numeric', 
        hour: '2-digit', 
        minute: '2-digit' 
      }),
    };
    const updated = [entry, ...entries];
    setEntries(updated);
    localStorage.setItem('bioscope_journals', JSON.stringify(updated));
  };

  const deleteEntry = (id: string) => {
    if (confirm("Hapus jurnal ini?")) {
      const updated = entries.filter(e => e.id !== id);
      setEntries(updated);
      localStorage.setItem('bioscope_journals', JSON.stringify(updated));
    }
  };

  const filteredEntries = entries.filter(e => 
    e.topic.toLowerCase().includes(filter.toLowerCase())
  );

  return (
    <div className="min-h-screen bg-slate-50 p-4 md:p-8 text-slate-900 font-sans">
      <div className="max-w-6xl mx-auto space-y-8">
        
        {/* Header & Stats */}
        <div className="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 bg-white p-8 rounded-[2rem] border-4 border-black shadow-[8px_8px_0_0_#000]">
          <div>
            <h1 className="text-4xl font-black uppercase italic tracking-tighter">Learning Journal</h1>
            <p className="text-slate-500 font-bold">Refleksikan perjalanan biologimu hari ini.</p>
          </div>
          <div className="flex gap-4">
            <div className="bg-indigo-100 p-4 rounded-2xl border-2 border-indigo-600 text-center min-w-[100px]">
              <p className="text-[10px] font-black uppercase text-indigo-600">Total Jurnal</p>
              <p className="text-2xl font-black">{entries.length}</p>
            </div>
            <div className="bg-green-100 p-4 rounded-2xl border-2 border-green-600 text-center min-w-[100px]">
              <p className="text-[10px] font-black uppercase text-green-600">Terakhir Update</p>
              <p className="text-sm font-black mt-1">{entries[0] ? entries[0].date.split(' pukul')[0] : '-'}</p>
            </div>
          </div>
        </div>

        <div className="grid grid-cols-1 lg:grid-cols-12 gap-8">
          {/* Kiri: Form Input */}
          <div className="lg:col-span-5">
            <JournalForm onSave={saveEntry} />
          </div>

          {/* Kanan: History & List */}
          <div className="lg:col-span-7 space-y-6">
            <div className="flex items-center gap-4 bg-white p-4 rounded-2xl border-2 border-black shadow-[4px_4px_0_0_#000]">
              <input 
                type="text" 
                placeholder="Cari topik jurnal..." 
                className="flex-1 outline-none font-bold bg-transparent"
                value={filter}
                onChange={(e) => setFilter(e.target.value)}
              />
              <BookText className="text-slate-400" />
            </div>
            
            <JournalList 
              entries={filteredEntries} 
              onDelete={deleteEntry} 
            />
          </div>
        </div>
      </div>
    </div>
  );
}